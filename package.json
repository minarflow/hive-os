{
  "name": "hive-os",
  "version": "0.1.0",
  "private": true,
  "description": "Hermes-first Team Mode PWA workspace",
  "scripts": {
    "dev": "bash scripts/dev",
    "build": "bash scripts/build",
    "test": "cd apps/api && .venv/bin/python -m pytest -q tests && npm --prefix apps/web run build",
    "doctor": "bash scripts/hive-os doctor",
    "serve": "bash scripts/hive-os serve",
    "install:local": "sudo bash scripts/install-local"
  }
}
