#!/usr/bin/env bash
# Seed demo data into the dev instance (idempotent). Run while or before `scripts/dev`.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
API_DIR="$ROOT/apps/api"
DEV_ROOT="${HIVEOS_DEV_ROOT:-$HOME/.local/share/hive-os-dev}"
export HIVEOS_DB_PATH="${HIVEOS_DB_PATH:-$DEV_ROOT/hive-os-dev.db}"
export HIVEOS_WORKSPACE_ROOT="${HIVEOS_WORKSPACE_ROOT:-$DEV_ROOT}"
( cd "$API_DIR" && uv run python scripts/seed_demo.py )
