# Hive OS local/team install config
# Copy to ~/.config/hive-os/hive-os.env or /etc/hive-os/hive-os.env

HIVEOS_REPO_ROOT="/opt/hive-os"
HIVEOS_DATA_DIR="/var/lib/hive-os"
HIVEOS_DB_PATH="/var/lib/hive-os/hive-os.db"
HIVEOS_WORKSPACE_ROOT="/var/lib/hive-os/workspace"
HIVEOS_HERMES_PROFILES_ROOT="/var/lib/hive-os/hermes-profiles"
HIVEOS_WEB_DIST="/opt/hive-os/apps/web/dist"
HIVEOS_HOST="127.0.0.1"
HIVEOS_PORT="8765"

# Team Mode is app-level isolation by default. This no-op helper avoids requiring sudo/ACL.
# Remove or replace with infra/scripts/hiveosctl when enabling real filesystem ACLs.
HIVEOS_PROJECTCTL_COMMAND="/usr/bin/true"

# Optional run settings
HIVEOS_RUN_TIMEOUT_SECONDS="300"
HIVEOS_RUN_WORKER_POLL_MS="250"
