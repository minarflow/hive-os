#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PREFIX="${PREFIX:-/opt/hive-os}"
BIN="${BIN:-/usr/local/bin/hive-os}"
DATA_DIR="${HIVEOS_DATA_DIR:-/var/lib/hive-os}"
CONFIG_DIR="${HIVEOS_CONFIG_DIR:-/etc/hive-os}"
DRY_RUN=0
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=1

run() {
  if [[ "$DRY_RUN" == 1 ]]; then echo "+ $*"; else "$@"; fi
}

if [[ "$EUID" -ne 0 ]]; then
  echo "install-local must run with sudo/root (use --dry-run to preview)" >&2
  exit 1
fi

command -v uv >/dev/null 2>&1 || { echo "missing uv" >&2; exit 1; }
command -v npm >/dev/null 2>&1 || { echo "missing npm" >&2; exit 1; }

echo "Installing Hive OS"
echo "  source: $ROOT"
echo "  prefix: $PREFIX"
echo "  data:   $DATA_DIR"
echo "  config: $CONFIG_DIR/hive-os.env"
echo "  bin:    $BIN"

run mkdir -p "$PREFIX" "$DATA_DIR" "$CONFIG_DIR" "$(dirname "$BIN")"
run rsync -a --delete --exclude node_modules --exclude .venv --exclude dist --exclude .dev "$ROOT/" "$PREFIX/"
run bash "$PREFIX/scripts/build"
run ln -sf "$PREFIX/scripts/hive-os" "$BIN"

if [[ ! -f "$CONFIG_DIR/hive-os.env" ]]; then
  if [[ "$DRY_RUN" == 1 ]]; then
    echo "+ write $CONFIG_DIR/hive-os.env"
  else
    cat >"$CONFIG_DIR/hive-os.env" <<EOF
HIVEOS_REPO_ROOT="$PREFIX"
HIVEOS_DATA_DIR="$DATA_DIR"
HIVEOS_DB_PATH="$DATA_DIR/hive-os.db"
HIVEOS_WORKSPACE_ROOT="$DATA_DIR/workspace"
HIVEOS_HERMES_PROFILES_ROOT="$DATA_DIR/hermes-profiles"
HIVEOS_WEB_DIST="$PREFIX/apps/web/dist"
HIVEOS_HOST="127.0.0.1"
HIVEOS_PORT="8765"
HIVEOS_PROJECTCTL_COMMAND="/usr/bin/true"
EOF
  fi
fi

echo "Install complete. Next:"
echo "  hive-os doctor"
echo "  hive-os serve"
echo "  open http://127.0.0.1:8765"
